# Loaded only under `astro dev` (never by `astro build`). Safe to commit —
# contains no secrets, only dev-mode flags.

# Enable the dev-only fake login/signup flow (src/lib/dev-auth.ts, /dev/login).
# Lets you create and switch fake users without Clerk email verification.
# This has no effect in production builds: the code paths are gated on
# import.meta.env.DEV, which is compile-time `false` when building.
PUBLIC_DEV_FAKE_AUTH=true
