---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  /**
   * Adds umami-kit event tracking (scroll depth, time-on-page, clicks,
   * page-exit) on top of the basic Umami pageview. Enabled only on the
   * public marketing/signup pages — the logged-in app is not instrumented.
   */
  enhancedTracking?: boolean;
}

const {
  title,
  description = 'PackZen - A mobile-first packing list app for mindful travel',
  ogImage = '/packzen-og-image.png',
  ogType = 'website',
  enhancedTracking = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://packzen.org');
const ogImageURL = new URL(ogImage, Astro.site || 'https://packzen.org');
---

<!doctype html>
<html
  lang="en"
  data-umami-auto-track={enhancedTracking || undefined}
  data-umami-auto-track-all-clicks={enhancedTracking ? 'true' : undefined}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="PackZen" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />

    <!-- Icons -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- PWA Meta Tags -->
    <meta name="theme-color" content="#2563eb" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="PackZen" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script
      is:inline
      defer
      src="https://analytics.oberbrunner.com/script.js"
      data-website-id="02fcf573-fc08-4e95-89d7-3541b6ff7296"
      data-domains="packzen.org,www.packzen.org"></script>
    <!-- Matomo (trial alongside Umami); cookie-less, prod hostnames only -->
    <script is:inline>
      if (['packzen.org', 'www.packzen.org'].includes(location.hostname)) {
        var _paq = (window._paq = window._paq || []);
        _paq.push(['disableCookies']);
        _paq.push(['trackPageView']);
        _paq.push(['enableLinkTracking']);
        _paq.push(['setTrackerUrl', 'https://matomo.oberbrunner.com/matomo.php']);
        _paq.push(['setSiteId', '6']);
        var mg = document.createElement('script');
        mg.async = true;
        mg.src = 'https://matomo.oberbrunner.com/matomo.js';
        document.head.appendChild(mg);
      }
    </script>
    {
      /* umami-kit (vendored from https://github.com/rhelmer/umami-kit);
         auto-inits from the data-umami-* attributes on <html>. */
      enhancedTracking && <script is:inline defer src="/umami-kit.js" />
    }
  </head>
  <body>
    <slot />

    <!-- Service Worker Registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register('/sw.js')
            .then((registration) => {
              console.log('ServiceWorker registered:', registration.scope);
            })
            .catch((error) => {
              console.log('ServiceWorker registration failed:', error);
            });
        });
      }
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
