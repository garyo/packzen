---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SignIn, SignedIn, SignedOut } from '@clerk/astro/components';
import { DEV_FAKE_AUTH } from '../lib/dev-auth';
---

<BaseLayout title="Sign In - PackZen" enhancedTracking>
  <div class="flex min-h-screen items-center justify-center bg-gray-50 px-4 py-12">
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <h1 class="mb-2 text-3xl font-bold text-gray-900">Welcome Back</h1>
        <p class="text-gray-600">Sign in to access your packing lists</p>
      </div>

      <div class="flex justify-center">
        <SignedOut>
          <!--
            Clerk's <SignIn> renders its own loading + error states, fixing the
            empty-box problem. It natively reads the `redirect_url` query param
            for the post-sign-in redirect and preserves it on the sign-up link,
            so `fallbackRedirectUrl` only applies when `redirect_url` is absent.
          -->
          <SignIn signUpUrl="/sign-up" fallbackRedirectUrl="/dashboard" />
        </SignedOut>
        <SignedIn>
          <p class="text-gray-600">You're already signed in. Redirecting…</p>
        </SignedIn>
      </div>

      {
        DEV_FAKE_AUTH && (
          <div class="mt-6 text-center">
            <a href="/dev/login" class="text-sm text-gray-500 underline hover:text-gray-700">
              → Dev login (fake auth)
            </a>
          </div>
        )
      }
    </div>
  </div>
</BaseLayout>

<script>
  import { isSignedIn } from '../lib/clerk';

  // Already signed in → go straight to the dashboard.
  (async () => {
    if (await isSignedIn()) {
      window.location.replace('/dashboard');
    }
  })();
</script>
