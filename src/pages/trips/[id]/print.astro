---
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';

const { id } = Astro.params;
const sortBy = Astro.url.searchParams.get('sortBy') || 'bag';
const columnsParam = Astro.url.searchParams.get('columns');
const columns = columnsParam === '1' ? '1' : '2';
const includeSkipped = Astro.url.searchParams.get('includeSkipped') === '1';
---

<BaseLayout title="Print Checklist - PackZen">
  <div
    id="app-root"
    data-trip-id={id}
    data-sort-by={sortBy}
    data-columns={columns}
    data-columns-explicit={columnsParam !== null ? '1' : '0'}
    data-include-skipped={includeSkipped ? '1' : '0'}
  >
  </div>
</BaseLayout>

<script>
  import { render } from 'solid-js/web';
  import {
    TripPrintView,
    PRINT_COLUMNS_STORAGE_KEY,
  } from '../../../components/trips/TripPrintView';
  import { isSignedIn } from '../../../lib/clerk';

  // Client-side auth gate. Waits for Clerk to load, then either redirects to
  // sign-in or mounts the app.
  (async () => {
    if (!(await isSignedIn())) {
      const path = window.location.pathname + window.location.search;
      window.location.replace(`/sign-in?redirect_url=${encodeURIComponent(path)}`);
      return;
    }

    const root = document.getElementById('app-root');
    const tripId = root?.dataset.tripId;
    const sortBy = (root?.dataset.sortBy as 'bag' | 'category') || 'bag';
    const includeSkipped = root?.dataset.includeSkipped === '1';

    // The header's print link only carries `sortBy`, so when the column count
    // wasn't given explicitly, fall back to the user's last choice instead of
    // silently resetting to the 2-column default every time.
    let columns = root?.dataset.columns === '2' ? 2 : 1;
    if (root?.dataset.columnsExplicit !== '1') {
      const saved = window.localStorage.getItem(PRINT_COLUMNS_STORAGE_KEY);
      if (saved === '1' || saved === '2') columns = Number(saved);
    }

    if (root && tripId) {
      render(
        () =>
          TripPrintView({
            tripId,
            sortBy,
            initialColumns: columns,
            initialIncludeSkipped: includeSkipped,
          }),
        root
      );
    }
  })();
</script>
