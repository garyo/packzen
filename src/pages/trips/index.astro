---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Trips - PackZen">
  <div id="app-root"></div>
</BaseLayout>

<script>
  import { render } from 'solid-js/web';
  import { TripsPage } from '../../components/trips/TripsPage';
  import { isSignedIn } from '../../lib/clerk';

  // Client-side auth gate (static output, so no server guard). Waits for Clerk
  // to load, then either redirects to sign-in or mounts the app.
  (async () => {
    if (!(await isSignedIn())) {
      const path = window.location.pathname + window.location.search;
      window.location.replace(`/sign-in?redirect_url=${encodeURIComponent(path)}`);
      return;
    }

    const root = document.getElementById('app-root');
    if (root) {
      render(TripsPage, root);
    }
  })();
</script>
